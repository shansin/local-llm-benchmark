# Ollama API endpoint
OLLAMA_BASE_URL=http://localhost:11434

# Models to benchmark (comma-separated, or "all" to benchmark all, empty to prompt interactively)
BENCHMARK_MODELS=

# Judge model name (empty to prompt interactively)
JUDGE_MODEL=

# Prompts directory
PROMPTS_DIR=./prompts

# Prompt criteria / expected answers directory
CRITERIA_DIR=./prompts_criteria

# Output directory
OUTPUT_DIR=./output

# Timeout per prompt in seconds (default: 2700 = 45 minutes)
PROMPT_TIMEOUT=2700
